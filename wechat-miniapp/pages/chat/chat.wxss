.chat-page {
  padding-bottom: 160rpx;
}

.summary-card {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 24rpx;
  border: 1rpx solid rgba(125, 211, 252, 0.2);
  border-radius: 28rpx;
  background: rgba(31, 34, 50, 0.96);
  box-shadow: 0 28rpx 80rpx rgba(0, 0, 0, 0.28);
}

.summary-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.summary-label {
  color: #7f89a6;
  font-size: 22rpx;
  font-weight: 800;
}

.summary-title {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.summary-route {
  margin-top: 10rpx;
  color: #c5c9d8;
  font-size: 24rpx;
  font-weight: 700;
}

.status-pill {
  height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.15);
  color: #e0f2fe;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 22rpx;
}

.summary-cell {
  padding: 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.06);
  color: #c5c9d8;
  font-size: 22rpx;
}

.chat-list {
  padding: 32rpx 0;
}

.chat-row {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
  margin-top: 20rpx;
}

.chat-row.mine {
  justify-content: flex-end;
}

.chat-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid rgba(125, 211, 252, 0.25);
  border-radius: 999rpx;
  background: rgba(125, 211, 252, 0.14);
  color: #e0f2fe;
  font-size: 24rpx;
  font-weight: 900;
}

.bubble {
  max-width: 76%;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  background: rgba(31, 34, 50, 0.96);
  color: #f7f8ff;
  font-size: 26rpx;
  line-height: 1.5;
}

.my-bubble {
  border-color: transparent;
  background: #38bdf8;
  color: #ffffff;
}

.bubble-author {
  margin-bottom: 6rpx;
  font-size: 20rpx;
  font-weight: 900;
  opacity: 0.75;
}

.input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  gap: 12rpx;
  box-sizing: border-box;
  padding: 16rpx 28rpx calc(env(safe-area-inset-bottom) + 18rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(5, 9, 24, 0.9);
}

.chat-input {
  flex: 1;
  min-height: 88rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 26rpx;
  padding: 0 24rpx;
}

.send-button {
  width: 130rpx;
  min-height: 88rpx;
  border-radius: 22rpx;
  background: #38bdf8;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}
