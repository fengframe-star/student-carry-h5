.no-margin {
  margin-top: 0;
}

.how-section {
  margin-top: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 20% 0%, rgba(56, 189, 248, 0.18), transparent 34%),
    rgba(31, 34, 50, 0.92);
  box-shadow: 0 28rpx 80rpx rgba(0, 0, 0, 0.28);
}

.stack-stage {
  position: relative;
  height: 500rpx;
  margin-top: 24rpx;
}

.stack-card {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  box-sizing: border-box;
  min-height: 390rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 28rpx;
  background: rgba(23, 27, 43, 0.96);
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.28);
  transition: transform 0.45s ease, opacity 0.45s ease;
}

.pos-0 {
  z-index: 3;
  opacity: 1;
  transform: translateY(0) scale(1);
}

.pos-1 {
  z-index: 2;
  opacity: 0.62;
  transform: translateY(42rpx) scale(0.94);
}

.pos-2 {
  z-index: 1;
  opacity: 0.36;
  transform: translateY(84rpx) scale(0.88);
}

.stack-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.step-number {
  color: #bae6fd;
  font-size: 22rpx;
  font-weight: 900;
}

.step-title {
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.step-en {
  margin-top: 6rpx;
  color: #aeb6d9;
  font-size: 24rpx;
  font-weight: 700;
}

.step-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border: 1rpx solid rgba(56, 189, 248, 0.3);
  border-radius: 28rpx;
  background: rgba(56, 189, 248, 0.15);
  color: #7dd3fc;
  font-size: 24rpx;
  font-weight: 900;
}

.step-body {
  margin-top: 34rpx;
  color: #dfe3ff;
  font-size: 26rpx;
  line-height: 1.55;
}

.dots {
  display: flex;
  justify-content: center;
  gap: 14rpx;
  margin-top: 10rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
}

.active-dot-mini {
  width: 48rpx;
  background: #38bdf8;
}

.example-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(125, 211, 252, 0.2);
  border-radius: 24rpx;
  background: rgba(7, 18, 35, 0.62);
}
