.login-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.login-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  min-height: 104rpx;
  box-sizing: border-box;
  margin-left: 0;
  margin-right: 0;
  padding: 12rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  text-align: center;
  white-space: pre-line;
  word-break: break-word;
}

.small-button {
  min-height: 64rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  line-height: 64rpx;
}

.item-title {
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
}

.item-line {
  margin-top: 10rpx;
  color: #aeb6d9;
  font-size: 26rpx;
  line-height: 1.5;
  word-break: break-word;
}
