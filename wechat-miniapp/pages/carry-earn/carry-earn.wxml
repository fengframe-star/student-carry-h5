<view class="page">
  <button class="back-button" bindtap="goBack">← 返回 / Back</button>

  <view class="eyebrow">
    <text class="cn">顺路送</text>
    <text class="en">Carry</text>
  </view>
  <view class="title">顺路送</view>
  <view class="subtitle">
    <text class="cn">填写你的路线和可用行李空间，方便后续匹配合适需求。</text>
    <text class="en">Add your route and available space so admins can match you with a suitable request.</text>
  </view>

  <form bindsubmit="submitForm">
    <view class="card">
      <view class="field">
        <text class="label">姓名\nName</text>
        <input class="input" name="name" placeholder="张三 / Alex" />
      </view>
      <view class="notice compact-notice">
        <text class="cn">联系方式将通过平台消息系统进行沟通。</text>
        <text class="en">Contact details will be handled through the platform messaging system.</text>
      </view>
      <view class="field">
        <text class="label">出发国家\nFrom country</text>
        <picker value="{{fromCountryIndex}}" range="{{countryNames}}" bindchange="onFromCountryChange">
          <view class="picker">{{countryNames[fromCountryIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">出发城市\nFrom city</text>
        <picker value="{{fromCityIndex}}" range="{{fromCityOptions}}" bindchange="onFromCityChange">
          <view class="picker">{{fromCityOptions[fromCityIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">到达国家\nTo country</text>
        <picker value="{{toCountryIndex}}" range="{{countryNames}}" bindchange="onToCountryChange">
          <view class="picker">{{countryNames[toCountryIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">到达城市\nTo city</text>
        <picker value="{{toCityIndex}}" range="{{toCityOptions}}" bindchange="onToCityChange">
          <view class="picker">{{toCityOptions[toCityIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">旅行日期\nTravel date</text>
        <picker mode="date" value="{{travelDate}}" bindchange="onTravelDateChange">
          <view class="picker">{{travelDate || "Select date / 选择日期"}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">可接受物品类型\nAccepted item type</text>
        <picker value="{{itemCategoryIndex}}" range="{{itemCategories}}" bindchange="onItemCategoryChange">
          <view class="picker">{{itemCategories[itemCategoryIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">可用行李空间\nAvailable luggage space</text>
        <input class="input" name="availableLuggageSpace" placeholder="3 kg / shoebox size" />
      </view>
      <view class="field">
        <text class="label">期望报酬\nExpected reward</text>
        <input class="input" name="expectedReward" placeholder="EUR 20-35" />
      </view>
      <view class="field">
        <text class="label">备注\nNotes</text>
        <textarea class="textarea" name="notes" placeholder="交接偏好或时间 / Handoff preferences or timing" />
      </view>
    </view>

    <view class="notice">
      <text class="cn">禁止危险品、武器、非法物质、受限制电池、大容量液体、灰产代购或转售物品。</text>
      <text class="en">Dangerous goods, weapons, illegal substances, restricted batteries, large liquids, and gray-market reselling items are not allowed.</text>
    </view>

    <label class="checkbox-row">
      <checkbox value="agreed" checked="{{agreed}}" bindtap="toggleAgreed" />
      <text>我同意遵守平台规则，并确认物品需符合出发地、航空公司与目的地国家/地区规定。\nI agree to follow platform rules and confirm items must comply with airline, customs, and destination regulations.</text>
    </label>

    <button class="primary-button submit-button" form-type="submit">查看匹配建议 / Review matching requests</button>
  </form>

  <view class="match-section" wx:if="{{showingMatches}}">
    <view class="card">
      <view class="item-title">可能匹配的帮我带</view>
      <view class="item-line">Possible matching requests</view>

      <block wx:if="{{matchingRequests.length}}">
        <view class="mini-card" wx:for="{{matchingRequests}}" wx:key="_id">
          <view class="mini-row">
            <view class="mini-route">{{item.fromLocation}} → {{item.toLocation}}</view>
            <view class="status-badge">{{item.status || "Open"}}</view>
          </view>
          <view class="mini-main">{{item.itemName}}</view>
          <view class="mini-line">{{item.itemCategory || "Others"}} · {{item.desiredDeliveryDate}}</view>
          <view class="mini-line">€{{item.budgetEur}} · Completed: 5 · Active today</view>
        </view>
      </block>

      <view class="notice compact-notice" wx:else>
        <text class="cn">暂时没有明显匹配的帮我带。</text>
        <text class="en">No strong request matches yet.</text>
      </view>

      <button class="primary-button submit-button" wx:if="{{matchingRequests.length}}" bindtap="contactRequestUser">Contact Request User</button>
      <button class="secondary-button submit-button" bindtap="publishPendingCarry">Still Publish Carry Post</button>
    </view>
  </view>
</view>
