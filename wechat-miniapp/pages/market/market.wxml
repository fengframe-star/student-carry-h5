<view class="page">
  <view class="hero">
    <view class="eyebrow">Market</view>
    <view class="title">匹配集市</view>
    <view class="subtitle">
      <text class="cn">选择你想要查看的类型</text>
      <text class="en">Choose the type you want to view</text>
    </view>
    <view class="market-actions">
      <button class="{{activeType === 'request' ? 'primary-button market-button' : 'secondary-button market-button'}}" data-type="request" bindtap="setType">帮我带</button>
      <button class="{{activeType === 'carrier' ? 'primary-button market-button' : 'secondary-button market-button'}}" data-type="carrier" bindtap="setType">顺路送</button>
    </view>
  </view>

  <view class="search-card">
    <view class="search-head">
      <view>
        <view class="search-title">自定义搜索</view>
        <view class="search-subtitle">City to city</view>
      </view>
      <button class="clear-button" bindtap="clearSearch">清除 / Clear</button>
    </view>
    <view class="search-grid">
      <picker value="{{fromCountryIndex}}" range="{{searchCountries}}" bindchange="onFromCountryChange">
        <view class="search-picker">{{searchCountries[fromCountryIndex]}}</view>
      </picker>
      <picker value="{{fromCityIndex}}" range="{{fromCityOptions}}" bindchange="onFromCityChange">
        <view class="search-picker">{{fromCityOptions[fromCityIndex]}}</view>
      </picker>
      <picker value="{{toCountryIndex}}" range="{{searchCountries}}" bindchange="onToCountryChange">
        <view class="search-picker">{{searchCountries[toCountryIndex]}}</view>
      </picker>
      <picker value="{{toCityIndex}}" range="{{toCityOptions}}" bindchange="onToCityChange">
        <view class="search-picker">{{toCityOptions[toCityIndex]}}</view>
      </picker>
    </view>
  </view>

  <view class="grid-list" wx:if="{{activeType === 'request'}}">
    <view class="mini-card" wx:for="{{requests}}" wx:key="_id">
      <view class="mini-route">{{item.fromLocation}} → {{item.toLocation}}</view>
      <view class="mini-main">{{item.itemName}}</view>
      <view class="mini-line">{{item.desiredDeliveryDate}}</view>
      <view class="mini-price">€{{item.budgetEur}}</view>
    </view>
  </view>
  <view class="card muted" wx:if="{{activeType === 'request' && !requests.length}}">
    暂无帮我带发布
    <text class="en">No request posts yet.</text>
  </view>

  <view class="grid-list" wx:if="{{activeType === 'carrier'}}">
    <view class="mini-card" wx:for="{{carriers}}" wx:key="_id">
      <view class="mini-route">{{item.travelRoute}}</view>
      <view class="mini-main">{{item.availableLuggageSpace}}</view>
      <view class="mini-line">{{item.travelDate}}</view>
      <view class="mini-price">{{item.expectedReward}}</view>
    </view>
  </view>
  <view class="card muted" wx:if="{{activeType === 'carrier' && !carriers.length}}">
    暂无顺路送发布
    <text class="en">No carry posts yet.</text>
  </view>
</view>
