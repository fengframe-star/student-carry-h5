.market-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 32rpx;
}

.market-button {
  width: calc((100% - 28rpx) / 3);
  flex: 0 0 calc((100% - 28rpx) / 3);
  min-width: 0;
  padding-left: 10rpx;
  padding-right: 10rpx;
}

.mini-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10rpx;
}

.status-badge {
  flex-shrink: 0;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.15);
  padding: 6rpx 12rpx;
  color: #e0f2fe;
  font-size: 18rpx;
  font-weight: 900;
}

.search-card {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  background: rgba(31, 34, 50, 0.9);
  box-shadow: 0 16rpx 44rpx rgba(0, 0, 0, 0.18);
}

.search-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.search-title {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}

.search-subtitle {
  margin-top: 2rpx;
  color: #aeb6d9;
  font-size: 20rpx;
}

.clear-button {
  min-height: 52rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #c5c9d8;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 52rpx;
}

.search-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  margin-top: 14rpx;
}

.search-picker {
  min-height: 58rpx;
  box-sizing: border-box;
  padding: 12rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.07);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 34rpx;
}

.grid-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.mini-card {
  min-width: 0;
  min-height: 210rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 28rpx;
  background: rgba(31, 34, 50, 0.92);
  box-shadow: 0 20rpx 56rpx rgba(0, 0, 0, 0.22);
}

.mini-route {
  color: #aeb6d9;
  font-size: 22rpx;
  line-height: 1.35;
  word-break: break-word;
}

.mini-main {
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
  word-break: break-word;
}

.mini-line {
  margin-top: 14rpx;
  color: #c5c9d8;
  font-size: 24rpx;
  word-break: break-word;
}

.mini-price {
  margin-top: 14rpx;
  color: #38bdf8;
  font-size: 28rpx;
  font-weight: 900;
  word-break: break-word;
}
