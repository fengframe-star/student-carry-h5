.market-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 32rpx;
}

.market-button {
  width: calc((100% - 14rpx) / 2);
  flex: 0 0 calc((100% - 14rpx) / 2);
  min-width: 0;
  padding-left: 10rpx;
  padding-right: 10rpx;
}

.grid-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 28rpx;
}

.mini-card {
  min-width: 0;
  min-height: 210rpx;
  box-sizing: border-box;
  padding: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 28rpx;
  background: rgba(31, 34, 50, 0.92);
  box-shadow: 0 20rpx 56rpx rgba(0, 0, 0, 0.22);
}

.mini-route {
  color: #aeb6d9;
  font-size: 22rpx;
  line-height: 1.35;
  word-break: break-word;
}

.mini-main {
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
  word-break: break-word;
}

.mini-line {
  margin-top: 14rpx;
  color: #c5c9d8;
  font-size: 24rpx;
  word-break: break-word;
}

.mini-price {
  margin-top: 14rpx;
  color: #38bdf8;
  font-size: 28rpx;
  font-weight: 900;
  word-break: break-word;
}
