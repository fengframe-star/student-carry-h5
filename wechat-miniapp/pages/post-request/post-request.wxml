<view class="page">
  <button class="back-button" bindtap="goBack">← 返回 / Back</button>

  <view class="eyebrow">
    <text class="cn">发布需求</text>
    <text class="en">Request</text>
  </view>
  <view class="title">帮我带</view>
  <view class="subtitle">
    <text class="cn">填写路线、物品信息和预算。请不要填写护照、身份证、签证或其他证件信息。</text>
    <text class="en">Share route, item details, and budget. Do not enter passport, national ID, visa, or identity document details.</text>
  </view>

  <form bindsubmit="submitForm">
    <view class="card">
      <view class="field">
        <text class="label">姓名\nName</text>
        <input class="input" name="name" placeholder="张三 / Alex" />
      </view>
      <view class="notice compact-notice">
        <text class="cn">联系方式将通过平台消息系统进行沟通。</text>
        <text class="en">Contact details will be handled through the platform messaging system.</text>
      </view>
      <view class="field">
        <text class="label">出发国家\nFrom country</text>
        <picker value="{{fromCountryIndex}}" range="{{countryNames}}" bindchange="onFromCountryChange">
          <view class="picker">{{countryNames[fromCountryIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">出发城市\nFrom city</text>
        <picker value="{{fromCityIndex}}" range="{{fromCityOptions}}" bindchange="onFromCityChange">
          <view class="picker">{{fromCityOptions[fromCityIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">到达国家\nTo country</text>
        <picker value="{{toCountryIndex}}" range="{{countryNames}}" bindchange="onToCountryChange">
          <view class="picker">{{countryNames[toCountryIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">到达城市\nTo city</text>
        <picker value="{{toCityIndex}}" range="{{toCityOptions}}" bindchange="onToCityChange">
          <view class="picker">{{toCityOptions[toCityIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">物品名称\nItem name</text>
        <input class="input" name="itemName" placeholder="课本 / Textbook" />
      </view>
      <view class="field">
        <text class="label">物品分类\nItem category</text>
        <picker value="{{itemCategoryIndex}}" range="{{itemCategories}}" bindchange="onItemCategoryChange">
          <view class="picker">{{itemCategories[itemCategoryIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">预估价值 EUR\nEstimated value in EUR</text>
        <input class="input" name="estimatedValueEur" type="digit" placeholder="50" />
      </view>
      <view class="field">
        <text class="label">期望送达日期\nDesired delivery date</text>
        <picker mode="date" value="{{desiredDeliveryDate}}" bindchange="onDeliveryDateChange">
          <view class="picker">{{desiredDeliveryDate || "Select date / 选择日期"}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">预算 EUR\nBudget in EUR</text>
        <input class="input" name="budgetEur" type="digit" placeholder="25" />
      </view>
      <view class="field">
        <text class="label">中国国内是否可邮寄？\nDomestic shipping in China available?</text>
        <picker value="{{shippingIndex}}" range="{{shippingOptions}}" bindchange="onShippingChange">
          <view class="picker">{{shippingOptions[shippingIndex]}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="label">备注\nNotes</text>
        <textarea class="textarea" name="notes" placeholder="尺寸、时间、交接方式 / Size, timing, handoff details" />
      </view>
    </view>

    <view class="notice">
      <text class="cn">禁止危险品、武器、非法物质、受限制电池、大容量液体、灰产代购或转售物品。</text>
      <text class="en">Dangerous goods, weapons, illegal substances, restricted batteries, large liquids, and gray-market reselling items are not allowed.</text>
      <text class="cn">如需中国国内转寄，可在聊天中沟通顺丰匿名寄件与运单信息。</text>
      <text class="en">If domestic forwarding in China is needed, SF anonymous shipping and tracking details can be discussed in chat.</text>
    </view>

    <label class="checkbox-row">
      <checkbox value="confirmed" checked="{{confirmed}}" bindtap="toggleConfirmed" />
      <text>我确认该物品不是限制、违法、奢侈、高价值或身份证件类物品，并符合出发地、航空公司与目的地国家/地区规定。\nI confirm this is not a restricted, illegal, luxury, high-value, or identity document item and complies with airline, customs, and destination regulations.</text>
    </label>

    <button class="primary-button submit-button" form-type="submit">查看匹配建议 / Review matching carriers</button>
  </form>

  <view class="match-section" wx:if="{{showingMatches}}">
    <view class="card">
      <view class="item-title">可能匹配的顺路送</view>
      <view class="item-line">Possible matching carry posts</view>

      <block wx:if="{{matchingCarriers.length}}">
        <view class="mini-card" wx:for="{{matchingCarriers}}" wx:key="_id">
          <view class="mini-row">
            <view class="mini-route">{{item.travelRoute}}</view>
            <view class="status-badge">{{item.status || "Open"}}</view>
          </view>
          <view class="mini-main">{{item.availableLuggageSpace}}</view>
          <view class="mini-line">{{item.travelDate}} · {{item.expectedReward}}</view>
          <view class="mini-line">Completed: 5 · Active today</view>
        </view>
      </block>

      <view class="notice compact-notice" wx:else>
        <text class="cn">暂时没有明显匹配的顺路送。</text>
        <text class="en">No strong carry matches yet.</text>
      </view>

      <button class="primary-button submit-button" wx:if="{{matchingCarriers.length}}" bindtap="contactMatchingCarrier">Contact Matching Carrier</button>
      <button class="secondary-button submit-button" bindtap="publishPendingRequest">Still Publish Request</button>
    </view>
  </view>
</view>
