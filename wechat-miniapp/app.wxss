page {
  min-height: 100%;
  background: #050918;
  color: #f7f8ff;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
  background:
    radial-gradient(circle at 22% 6%, rgba(56, 189, 248, 0.28), transparent 34%),
    radial-gradient(circle at 85% 18%, rgba(32, 199, 255, 0.14), transparent 30%),
    #050918;
}

.hero,
.card,
.list-item,
.dock {
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 32rpx;
  background: rgba(31, 34, 50, 0.92);
  box-shadow: 0 28rpx 80rpx rgba(0, 0, 0, 0.28);
}

.hero {
  padding: 32rpx;
}

.card,
.list-item {
  margin-top: 24rpx;
  padding: 28rpx;
}

.dock {
  margin-top: 24rpx;
  padding: 20rpx;
}

.accent-card {
  background: linear-gradient(135deg, #38bdf8 0%, #202438 72%);
}

.eyebrow {
  color: #aeb6d9;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.title {
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 800;
}

.subtitle {
  margin-top: 18rpx;
  color: #c5c9d8;
  font-size: 28rpx;
  line-height: 1.65;
}

.cn {
  display: block;
}

.en {
  display: block;
  margin-top: 6rpx;
  color: #aeb6d9;
}

.section-title {
  margin-top: 32rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
}

.muted {
  color: #aeb6d9;
}

.button-row {
  display: flex;
  gap: 14rpx;
  margin-top: 28rpx;
}

.primary-button,
.secondary-button,
.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  max-width: 100%;
  box-sizing: border-box;
  margin-left: 0;
  margin-right: 0;
  padding: 0 18rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
  text-align: center;
  white-space: normal;
  word-break: break-word;
}

.button-row .primary-button,
.button-row .secondary-button,
.button-row .ghost-button {
  width: calc((100% - 14rpx) / 2);
  min-width: 0;
  flex: 0 0 calc((100% - 14rpx) / 2);
}

.primary-button {
  background: #38bdf8;
  color: #ffffff;
}

.secondary-button {
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
}

.ghost-button {
  background: transparent;
  color: #c5c9d8;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.back-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  box-sizing: border-box;
  margin-bottom: 22rpx;
  padding: 0 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #eef1ff;
  font-size: 24rpx;
  font-weight: 800;
}

.field {
  margin-top: 24rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #eef1ff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.45;
  white-space: pre-line;
}

input,
textarea,
picker {
  width: 100%;
  box-sizing: border-box;
}

.input,
.textarea,
.picker {
  min-height: 84rpx;
  box-sizing: border-box;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.07);
  color: #ffffff;
  font-size: 28rpx;
}

.compact-picker {
  min-height: 58rpx;
  padding: 10rpx 18rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  line-height: 38rpx;
}

.textarea {
  min-height: 180rpx;
}

.checkbox-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(56, 189, 248, 0.16);
  color: #d7dbef;
  font-size: 26rpx;
  line-height: 1.55;
}

.notice {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(56, 189, 248, 0.26);
  border-radius: 24rpx;
  background: rgba(56, 189, 248, 0.14);
  color: #dfe3ff;
  font-size: 26rpx;
  line-height: 1.6;
}

.compact-notice {
  padding: 18rpx;
  font-size: 24rpx;
}

.danger-notice {
  border-color: rgba(255, 98, 98, 0.28);
  background: rgba(255, 98, 98, 0.12);
  color: #ffd8d8;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.09);
  color: #cfd5ff;
  font-size: 22rpx;
  font-weight: 800;
}

.row-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-sizing: border-box;
  min-height: 116rpx;
  padding: 20rpx 0;
}

.row-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
  word-break: break-word;
}

.row-subtitle {
  margin-top: 8rpx;
  color: #aeb6d9;
  font-size: 26rpx;
  word-break: break-word;
}

.chevron {
  color: #7f879d;
  font-size: 44rpx;
}

@media (prefers-color-scheme: light) {
  page {
    background: #f7f8fc;
    color: #111827;
  }

  .page {
    background: #f7f8fc;
  }

  .hero,
  .card,
  .list-item,
  .dock {
    border-color: rgba(17, 24, 39, 0.08);
    background: #ffffff;
    box-shadow: 0 24rpx 70rpx rgba(17, 24, 39, 0.08);
  }

  .accent-card {
    background: linear-gradient(135deg, #38bdf8 0%, #eef9ff 100%);
  }

  .title,
  .section-title,
  .label,
  .row-title {
    color: #111827;
  }

  .subtitle,
  .en,
  .muted,
  .row-subtitle {
    color: #596174;
  }

  .input,
  .textarea,
  .picker {
    border-color: rgba(17, 24, 39, 0.12);
    background: #f7f8fc;
    color: #111827;
  }

  .secondary-button {
    background: #f7f8fc;
    color: #111827;
    border-color: rgba(17, 24, 39, 0.12);
  }
}
